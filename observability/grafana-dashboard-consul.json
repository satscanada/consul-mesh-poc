{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "consul-mesh-poc — per-subset traffic, latency, error rate and active connections from Envoy sidecar metrics grouped by Consul destination subset labels",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Traffic Split",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "v1" }, "properties": [{ "id": "color", "value": { "fixedColor": "#1F60C4", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "v2" }, "properties": [{ "id": "color", "value": { "fixedColor": "#37872D", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "variant-a" }, "properties": [{ "id": "color", "value": { "fixedColor": "#1F60C4", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "variant-b" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FA6400", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (consul_destination_service_subset) (rate(envoy_cluster_upstream_rq_total{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\"}[1m]))",
          "legendFormat": "{{consul_destination_service_subset}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate per Subset (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "pieType": "pie" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (consul_destination_service_subset) (increase(envoy_cluster_upstream_rq_total{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\"}[5m]))",
          "legendFormat": "{{consul_destination_service_subset}}",
          "refId": "A"
        }
      ],
      "title": "Traffic Split (last 5 min)",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 10 }] }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (consul_destination_service_subset) (envoy_cluster_upstream_cx_active{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\"})",
          "legendFormat": "{{consul_destination_service_subset}} active conns",
          "refId": "A"
        }
      ],
      "title": "Active Connections per Subset",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (consul_destination_service_subset, le) (rate(envoy_cluster_upstream_rq_time_bucket{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\"}[1m])))",
          "legendFormat": "p50 {{consul_destination_service_subset}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (consul_destination_service_subset, le) (rate(envoy_cluster_upstream_rq_time_bucket{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\"}[1m])))",
          "legendFormat": "p95 {{consul_destination_service_subset}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (consul_destination_service_subset, le) (rate(envoy_cluster_upstream_rq_time_bucket{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\"}[1m])))",
          "legendFormat": "p99 {{consul_destination_service_subset}}",
          "refId": "C"
        }
      ],
      "title": "Latency Percentiles per Subset (ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (consul_destination_service_subset) (rate(envoy_cluster_upstream_rq_time_sum{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\"}[1m])) / sum by (consul_destination_service_subset) (rate(envoy_cluster_upstream_rq_time_count{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\"}[1m]))",
          "legendFormat": "avg {{consul_destination_service_subset}}",
          "refId": "A"
        }
      ],
      "title": "Average Latency per Subset (ms)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Error Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (consul_destination_service_subset) (rate(envoy_cluster_upstream_rq_xx{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\", envoy_response_code_class=\"5\"}[1m]))",
          "legendFormat": "5xx {{consul_destination_service_subset}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (consul_destination_service_subset) (rate(envoy_cluster_upstream_rq_xx{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\", envoy_response_code_class=\"4\"}[1m]))",
          "legendFormat": "4xx {{consul_destination_service_subset}}",
          "refId": "B"
        }
      ],
      "title": "Error Rate per Subset (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (consul_destination_service_subset) (rate(envoy_cluster_upstream_rq_xx{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\", envoy_response_code_class=\"5\"}[5m])) / sum by (consul_destination_service_subset) (rate(envoy_cluster_upstream_rq_total{consul_destination_service=\"api-server\", consul_destination_service_subset=~\"v1|v2|variant-a|variant-b\"}[5m]))",
          "legendFormat": "error % {{consul_destination_service_subset}}",
          "refId": "A"
        }
      ],
      "title": "Error Percentage per Subset (last 5 min)",
      "type": "gauge"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["consul", "envoy", "service-mesh"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "consul-mesh-poc — Envoy Per-Subset Metrics",
  "uid": "consul-mesh-poc-v1",
  "version": 2
}
