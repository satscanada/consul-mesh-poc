# .env.example — copy to .env and fill in real values before running deploy-all.sh
# .env is git-ignored and never committed.

# ─── CockroachDB connection ───────────────────────────────────────────────────
# Host of your CockroachDB cluster (no port)
DB_HOST=free-tier.cockroachlabs.cloud

# Database name (default: defaultdb)
DB_NAME=defaultdb

# SQL username
DB_USER=root

# SQL password
DB_PASSWORD=

# Enable TLS for the pg driver (set to "true" for CockroachDB Cloud)
DB_SSL=true

# Path to the CockroachDB CA certificate downloaded from the CockroachLabs Cloud UI:
#   curl --create-dirs -o $HOME/.postgresql/root.crt \
#     'https://cockroachlabs.cloud/clusters/<your-cluster-id>/cert'
DB_SSL_CERT_PATH=$HOME/.postgresql/root.crt

# ─── Kubernetes context guard ─────────────────────────────────────────────────
# The deploy script checks this. Change if you use a different context name.
KUBE_CONTEXT=docker-desktop

# ─── Docker image tags ────────────────────────────────────────────────────────
# Override to push images to a registry (e.g. ghcr.io/youruser/api-server:latest)
API_SERVER_IMAGE=api-server:latest
UI_APP_IMAGE=ui-app:latest
